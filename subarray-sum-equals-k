We use the Prefix Sum + HashMap technique. 
class Solution:
    def subarraySum(self, nums: List[int], k: int) -> int:
        n = len(nums)
        map = {0:1}
        rSum = 0
        result = 0


        for num in nums:
            rSum += num
            cmp = rSum - k
            if cmp in map:
                result += map[cmp]
            map[rSum] = map.get(rSum, 0) + 1

        return result 
